#!/usr/bin/env bash
# mdfmt — Format a Markdown file in place using Prettier (auto-aligns tables, etc).
#
# Usage:
#   mdfmt <file.md> [<file2.md> ...]
#   mdfmt --check <file.md>     # don't write, just report changes
#
# Runs prettier with markdown defaults; safe to run repeatedly (idempotent).

set -euo pipefail

if [ $# -eq 0 ]; then
    echo "Usage: mdfmt <file.md> [file2.md ...] [--check]" >&2
    exit 1
fi

if command -v bunx >/dev/null 2>&1; then
    RUNNER="bunx --bun prettier"
elif command -v npx >/dev/null 2>&1; then
    RUNNER="npx --yes prettier"
else
    echo "mdfmt: need bun or node installed" >&2
    exit 1
fi

CHECK=0
FILES=()
for arg in "$@"; do
    case "$arg" in
        --check) CHECK=1 ;;
        -h|--help)
            sed -n '2,10p' "$0" | sed 's/^# \{0,1\}//'
            exit 0 ;;
        *) FILES+=("$arg") ;;
    esac
done

if [ "$CHECK" = "1" ]; then
    $RUNNER --check --parser markdown "${FILES[@]}"
else
    $RUNNER --write --parser markdown --prose-wrap preserve "${FILES[@]}"
fi
